#!/usr/bin/env bash
# cache22-karg — manage persistent kernel command-line args.
# Edits /etc/cache22/extra-cmdline and triggers cache22-resign-uki to
# rebuild the per-deploy UKI with the new cmdline. The .path watcher
# on extra-cmdline also catches manual edits.
#
# Subcommands:
#   list                  show effective cmdline + user/image kargs
#   add KEY=VAL...        add args persistently
#   remove KEY...         remove args by key
#   reset                 clear all user-added args
#   --help

set -euo pipefail

CMDLINE_FILE=/etc/cache22/extra-cmdline

require_root() {
    [[ ${EUID} -eq 0 ]] || { echo "Error: must run as root (try: sudo cache22-karg $*)" >&2; exit 1; }
}

read_user_kargs() {
    [[ -f "$CMDLINE_FILE" ]] || return 0
    sed -e 's/[[:space:]]*#.*$//' -e '/^[[:space:]]*$/d' "$CMDLINE_FILE"
}

write_user_kargs() {
    local kargs=("$@")
    install -d -m0755 "$(dirname "$CMDLINE_FILE")"
    {
        echo "# User-managed kernel cmdline kargs. Edited by cache22-karg."
        echo "# Newline-separated. '#' comments and blank lines ignored."
        echo "# A change here triggers cache22-resign-uki via .path watcher."
        local k
        for k in "${kargs[@]}"; do
            [[ -z "$k" ]] && continue
            echo "$k"
        done
    } > "$CMDLINE_FILE"
}

apply() {
    if systemctl --quiet is-active cache22-resign-uki.service; then
        echo "==> cache22-resign-uki already running; will re-fire on .path change"
    else
        echo "==> Triggering cache22-resign-uki.service"
        systemctl start cache22-resign-uki.service
    fi
}

cmd_list() {
    echo "─── Booted cmdline ───"
    cat /proc/cmdline
    echo
    echo "─── User-managed kargs ($CMDLINE_FILE) ───"
    if [[ -s "$CMDLINE_FILE" ]] && read_user_kargs | grep -q .; then
        read_user_kargs
    else
        echo "(none)"
    fi
    echo
    echo "─── Image defaults (/usr/lib/bootc/kargs.d/*.toml) ───"
    if compgen -G "/usr/lib/bootc/kargs.d/*.toml" >/dev/null; then
        cat /usr/lib/bootc/kargs.d/*.toml
    else
        echo "(none)"
    fi
}

cmd_add() {
    require_root add "$@"
    [[ $# -ge 1 ]] || { echo "Usage: cache22-karg add KEY=VALUE [KEY=VALUE...]" >&2; exit 1; }

    local existing=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && existing+=("$line")
    done < <(read_user_kargs)

    local arg key
    for arg in "$@"; do
        key="${arg%%=*}"
        local kept=()
        for k in "${existing[@]:-}"; do
            [[ "${k%%=*}" != "$key" ]] && kept+=("$k")
        done
        kept+=("$arg")
        existing=("${kept[@]}")
    done

    write_user_kargs "${existing[@]}"
    echo "==> Wrote $CMDLINE_FILE"
    cat "$CMDLINE_FILE"
    apply
}

cmd_remove() {
    require_root remove "$@"
    [[ $# -ge 1 ]] || { echo "Usage: cache22-karg remove KEY [KEY...]" >&2; exit 1; }
    [[ -f "$CMDLINE_FILE" ]] || { echo "Nothing to remove (no $CMDLINE_FILE)."; exit 0; }

    local existing=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && existing+=("$line")
    done < <(read_user_kargs)

    local kept=()
    local k
    for k in "${existing[@]:-}"; do
        local lkey="${k%%=*}"
        local skip=0
        for arg in "$@"; do
            [[ "$lkey" == "$arg" ]] && { skip=1; break; }
        done
        [[ $skip -eq 0 ]] && kept+=("$k")
    done

    write_user_kargs "${kept[@]}"
    echo "==> Updated $CMDLINE_FILE"
    cat "$CMDLINE_FILE"
    apply
}

cmd_reset() {
    require_root reset
    write_user_kargs
    echo "==> Cleared $CMDLINE_FILE"
    apply
}

case "${1:-list}" in
    list)        cmd_list ;;
    add)         shift; cmd_add "$@" ;;
    remove|rm)   shift; cmd_remove "$@" ;;
    reset)       cmd_reset ;;
    -h|--help)   sed -n '2,13p' "$0" | sed 's/^# \?//' ;;
    *)
        echo "Usage: cache22-karg [list|add KEY=VAL...|remove KEY...|reset|--help]" >&2
        exit 1 ;;
esac
