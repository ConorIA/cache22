#!/usr/bin/env bash
# cache22-secureboot — manage the per-machine Secure Boot key + firmware
# DB enrollment. UKIs and sd-boot are signed locally with this key.
#
# Subcommands:
#   status                  Show SB state, key fingerprint, enrollment.
#   enable                  Generate key if missing, enroll into firmware
#                           DB (PK/KEK/db ours + Microsoft DB). Firmware
#                           must be in setup mode.
#   disable                 Switch sd-boot to no-auto-enroll, leave key
#                           on disk and Microsoft keys in DB.
#   rotate-keys             Generate fresh keys, re-enroll, re-sign
#                           sd-boot + every UKI, re-seal LUKS.
#   --help

set -euo pipefail

KEYDIR=/var/lib/cache22/sbkey
SBCRT="$KEYDIR/keys/db/db.pem"
ESP=/efi
[[ -d "$ESP" ]] || ESP=/boot/efi

require_root() {
    [[ ${EUID} -eq 0 ]] || { echo "Error: must run as root (try: sudo cache22-secureboot $*)" >&2; exit 1; }
}
die() { echo "Error: $*" >&2; exit 1; }

ensure_keys() { /usr/libexec/cache22/sb-key-init >/dev/null; }

cmd_status() {
    echo "─── Firmware ───"
    if [[ ! -d /sys/firmware/efi ]]; then
        echo "  Not booted in UEFI mode."
        return
    fi
    bootctl status 2>/dev/null | grep -iE 'secure boot|setup mode|firmware' | sed 's/^/  /' || true

    echo
    echo "─── Per-machine SB key ───"
    if [[ -f "$SBCRT" ]]; then
        openssl x509 -in "$SBCRT" -noout -subject -dates -fingerprint -sha256 2>/dev/null \
            | sed 's/^/  /'
    else
        echo "  Not generated yet — run 'sudo cache22-secureboot enable'."
    fi

    echo
    echo "─── sbctl enrollment ───"
    if command -v sbctl >/dev/null 2>&1; then
        sbctl status 2>&1 | sed 's/^/  /' || true
    fi

    echo
    echo "─── Booted UKI ───"
    local uki
    uki=$(find "$ESP/EFI/Linux" -maxdepth 1 -name 'cache22-*.efi' 2>/dev/null \
            | head -1)
    if [[ -n "$uki" ]]; then
        echo "  $uki"
        sbverify --list "$uki" 2>&1 | grep -E 'subject|issuer' | head -2 | sed 's/^/  /' || \
            echo "  (sbverify reports no signature)"
    else
        echo "  No cache22 UKI found in $ESP/EFI/Linux/"
    fi
}

cmd_enable() {
    require_root
    ensure_keys
    command -v sbctl >/dev/null 2>&1 || die "sbctl not installed"

    local sb_state
    sb_state=$(bootctl --print-secure-boot-state 2>/dev/null || echo unknown)
    local setup_mode
    setup_mode=$(bootctl --print-secure-boot-state 2>/dev/null | grep -iq 'setup' && echo yes || echo no)

    cat <<EOF
About to enroll the per-machine cache22 SB key into firmware DB.

This requires the firmware to be in *setup mode* (Platform Key cleared).
Enter your firmware setup utility, find Secure Boot settings, and
either:
  - Clear / reset / delete the Platform Key, OR
  - Switch SB mode to "Setup" / "Custom",
then save & exit. Boot back into cache22 and re-run this command.

Current state: SB=${sb_state}

Microsoft DB keys will be enrolled too (--microsoft) so any signed
binary you currently use (Windows, fwupd, signed firmware updates,
hardware option ROMs) keeps working.

EOF
    read -rp "Proceed with enrollment now? [y/N] " confirm
    [[ "${confirm,,}" == "y" ]] || { echo "Aborted."; exit 0; }

    echo "==> sbctl enroll-keys --microsoft"
    sbctl enroll-keys --microsoft 2>&1 | sed 's/^/    /'

    echo "==> Re-signing sd-boot + UKIs with the enrolled key"
    systemctl start cache22-resign-uki.service

    cat <<EOF

[OK] Enrollment complete.
  - SB DB now contains: cache22 PK/KEK/db + Microsoft DB keys.
  - sd-boot + all per-deploy UKIs re-signed with the cache22 key.

If LUKS+TPM auto-unlock is set up, run:
    sudo cache22-encryption enroll <device>
to (re-)bind the LUKS keyslot to the new SB state.

Reboot to verify everything boots end-to-end.
EOF
}

cmd_disable() {
    require_root
    command -v sbctl >/dev/null 2>&1 || die "sbctl not installed"

    cat <<EOF
About to:
  - reset the firmware DB so cache22 keys are no longer trusted
    (Microsoft DB keys remain),
  - leave the local key files at $KEYDIR (so re-enable is one
    command),
  - leave UKIs on the ESP signed (firmware will reject them while
    SB is on; you'll need to disable SB or re-enable cache22 keys).

EOF
    read -rp "Proceed? [y/N] " confirm
    [[ "${confirm,,}" == "y" ]] || { echo "Aborted."; exit 0; }

    sbctl reset 2>&1 | sed 's/^/    /' || true
    echo "[OK] Disabled. Boot proceeds with stock-MS-only DB until you re-enable."
}

cmd_rotate() {
    require_root
    cat <<EOF
About to rotate the per-machine SB + TPM signing keys. Steps:
  1. Move existing keys to $KEYDIR.old-$(date +%s)
  2. Generate fresh keys
  3. Re-enroll into firmware DB (requires setup mode again)
  4. Re-sign sd-boot + all UKIs
  5. Re-bind LUKS TPM keyslot to the new TPM key (if enrolled)

EOF
    read -rp "Proceed? [y/N] " confirm
    [[ "${confirm,,}" == "y" ]] || { echo "Aborted."; exit 0; }

    local backup="${KEYDIR}.old-$(date +%s)"
    mv "$KEYDIR" "$backup"
    echo "    backup: $backup"

    /usr/libexec/cache22/sb-key-init
    cmd_enable
}

case "${1:-status}" in
    status)            cmd_status ;;
    enable|enroll)     cmd_enable ;;
    disable|unenroll)  cmd_disable ;;
    rotate-keys)       cmd_rotate ;;
    -h|--help)         sed -n '2,15p' "$0" | sed 's/^# \?//' ;;
    *)
        echo "Usage: cache22-secureboot [status|enable|disable|rotate-keys|--help]" >&2
        exit 1 ;;
esac
