#!/usr/bin/env bash
# cache22-fast-reboot — kexec into the next UKI, skipping firmware POST.
#
# The userspace shutdown sequence (stop services, unmount fs, sync) runs
# normally — this is NOT like cutting power. Only firmware POST and the
# bootloader are bypassed. Net savings: 10-30 sec depending on how slow
# the firmware POST is.
#
# Picks the UKI sd-boot would auto-default to (highest .osrel
# VERSION_ID across cache22-*.efi). After cache22-update has staged a
# new deploy and resign-uki has built its UKI, that UKI is the highest
# VERSION_ID, so this script kexecs into the just-staged update.
#
# Flags:
#   --check         show what would be kexec'd; don't actually do it
#   --no-fallback   if kexec --load fails, abort instead of falling
#                   back to a normal systemctl reboot
#   --help

set -euo pipefail

CHECK=0
FALLBACK=1
for arg in "$@"; do
    case "$arg" in
        --check)        CHECK=1 ;;
        --no-fallback)  FALLBACK=0 ;;
        -h|--help)      sed -n '2,17p' "$0" | sed 's/^# \?//'; exit 0 ;;
        *)              echo "Unknown arg: $arg" >&2; exit 1 ;;
    esac
done

[[ ${EUID} -eq 0 ]] || { echo "Error: must run as root (try: sudo cache22-fast-reboot)" >&2; exit 1; }
die() { echo "Error: $*" >&2; exit 1; }

ESP=/efi
[[ -d "$ESP" ]] || ESP=/boot/efi
UKI_DIR="$ESP/EFI/Linux"
[[ -d "$UKI_DIR" ]] || die "ESP UKI directory not found at $UKI_DIR"

KEYDIR=/var/lib/cache22/sbkey
SBKEY="$KEYDIR/keys/db/db.key"
SBCRT="$KEYDIR/keys/db/db.pem"

# Pick the UKI sd-boot would auto-default to: highest VERSION_ID across
# cache22-*.efi. resign-uki stamps VERSION_ID = 1000 + N from the BLS
# entry's ostree-N.conf counter, so the staged deploy is always highest.
pick_uki() {
    local best="" best_ver=-1 uki ver osrel
    shopt -s nullglob
    for uki in "$UKI_DIR"/cache22-*.efi; do
        osrel=$(objcopy -O binary --only-section=.osrel "$uki" /dev/stdout 2>/dev/null \
                  | tr -d '\0' || true)
        ver=$(echo "$osrel" | sed -n 's/^VERSION_ID=//p' | head -1)
        [[ -z "$ver" ]] && continue
        if (( ver > best_ver )); then
            best_ver=$ver
            best="$uki"
        fi
    done
    shopt -u nullglob
    echo "$best"
}

UKI=$(pick_uki)
[[ -n "$UKI" ]] || die "No cache22 UKI found in $UKI_DIR"

echo "==> Target UKI: $(basename "$UKI")"

TMP=$(mktemp -d)
trap "rm -rf $TMP" EXIT

# Extract kernel + initramfs + cmdline from the signed PE.
objcopy -O binary --only-section=.linux   "$UKI" "$TMP/vmlinuz" 2>/dev/null \
    || die "Could not extract .linux section from $UKI"
objcopy -O binary --only-section=.initrd  "$UKI" "$TMP/initrd"  2>/dev/null \
    || die "Could not extract .initrd section from $UKI"
objcopy -O binary --only-section=.cmdline "$UKI" "$TMP/cmdline" 2>/dev/null \
    || die "Could not extract .cmdline section from $UKI"

# Strip embedded NULs that some sd-stub-generated .cmdline sections
# carry as a trailing terminator.
CMDLINE=$(tr -d '\0' < "$TMP/cmdline")
[[ -n "$CMDLINE" ]] || die "Extracted cmdline is empty"
echo "==> cmdline: $CMDLINE"

# Sign the extracted kernel with the per-machine SB key. Required for
# kexec under kernel lockdown (Fedora-style); harmless if lockdown is
# off (Arch/CachyOS default). Single script works either way.
if [[ -f "$SBKEY" && -f "$SBCRT" ]]; then
    if sbsign --key "$SBKEY" --cert "$SBCRT" --output "$TMP/vmlinuz.signed" "$TMP/vmlinuz" >/dev/null 2>&1; then
        mv "$TMP/vmlinuz.signed" "$TMP/vmlinuz"
        echo "==> kernel signed with per-machine SB key"
    else
        echo "    WARN: sbsign failed; using unsigned kernel (will fail under kernel lockdown)"
    fi
else
    echo "    NOTE: per-machine SB key not present; loading unsigned kernel"
fi

if (( CHECK )); then
    echo
    echo "── --check: extracted, not loading ──"
    ls -la "$TMP"
    exit 0
fi

echo "==> kexec --load"
if ! kexec --load \
        --kexec-syscall-auto \
        "$TMP/vmlinuz" \
        --initrd="$TMP/initrd" \
        --command-line="$CMDLINE"; then
    echo "    kexec --load FAILED"
    if (( FALLBACK )); then
        echo "==> falling back to systemctl reboot"
        exec systemctl reboot
    else
        die "kexec --load failed and --no-fallback set; system unchanged"
    fi
fi

echo "==> systemctl kexec (full clean shutdown then jump to staged kernel)"
exec systemctl kexec
