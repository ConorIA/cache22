#!/usr/bin/env bash
# cache22-update — pull + stage + finalize the next bootc image while
# the system is fully up. Moves the BLS-entry write earlier than bare
# `bootc upgrade` (which defers finalize until shutdown), so power loss
# between this returning and the user rebooting is benign.
# See docs/UPDATES.md.
#
# Subcommands:
#   (default)        check for + apply update; do NOT reboot
#   --check          read-only `bootc upgrade --check`
#   --reboot         apply + reboot
#   --app-updates    also: flatpak update -y; distrobox upgrade --all
#   --if-idle        exit silently if another cache22-update is already
#                    running (used by cache22-autoupdate.service so the
#                    timer never preempts an interactive run)
#   --help

set -euo pipefail

LOCK=/var/lock/cache22-update.lock

require_root() {
    if [[ ${EUID} -ne 0 ]]; then
        echo "Error: must run as root (try: sudo cache22-update $*)" >&2
        exit 1
    fi
}

REBOOT=0
APPS=0
CHECK=0
IF_IDLE=0
for arg in "$@"; do
    case "$arg" in
        --check)         CHECK=1 ;;
        --reboot)        REBOOT=1 ;;
        --app-updates)   APPS=1 ;;
        --if-idle)       IF_IDLE=1 ;;
        -h|--help)       sed -n '2,16p' "$0" | sed 's/^# \?//'; exit 0 ;;
        *)               echo "Unknown arg: $arg" >&2; exit 1 ;;
    esac
done

if (( CHECK )); then
    bootc upgrade --check
    exit $?
fi

require_root "$@"

# Acquire mutex so manual + automatic don't fight. Manual runs block;
# automatic (--if-idle) bows out silently.
exec 200>"$LOCK"
if (( IF_IDLE )); then
    if ! flock -nx 200; then
        echo "cache22-update is already running; skipping (--if-idle)"
        exit 0
    fi
else
    flock -x 200
fi

echo "==> Checking for remote update"
# Gate the actual pull behind --check. Without this, `bootc upgrade`
# will re-stage the same image even when there's nothing new at the
# registry — bootc's mental model is "make staged represent the
# latest", and it doesn't ask "is the existing pending already equal
# to the latest?". The result is daily redundant restages + UKI
# rebuilds when no upstream change has happened.
check_out=$(bootc upgrade --check 2>&1) || { echo "$check_out" >&2; exit 1; }
echo "$check_out"
if echo "$check_out" | grep -q '^No changes in:'; then
    echo "[OK] Nothing to fetch."
    exit 0
fi

echo "==> Pulling + staging next image (bootc upgrade)"
if ! bootc upgrade; then
    echo "ERROR: bootc upgrade failed" >&2
    exit 1
fi

# Was anything actually staged? bootc returns 0 even if a no-op slipped
# past --check (e.g. registry race), so still defend with jq.
if ! bootc status --json 2>/dev/null | jq -e '.status.staged != null' >/dev/null; then
    echo "[OK] Already up to date; nothing to finalize."
    exit 0
fi

# Standard bootc/ostree flow: the staged deploy stays in ostree's
# "staged" slot until shutdown, when ostree-finalize-staged.service's
# ExecStop writes the BLS entry. cache22's UKI build runs in the same
# shutdown step via the 50-cache22-uki.conf drop-in. So we don't
# finalize here, and we don't trigger the UKI build here — both happen
# during the next reboot's shutdown sequence.

# MOTD pending-reboot marker is now refreshed by
# /usr/libexec/cache22/refresh-pending-motd, also wired into
# cache22-pending-motd.service (WantedBy=multi-user.target +
# bootc-status-updated.target) so bare `bootc upgrade` gets the same
# behavior. We invoke it directly here so the marker reflects this
# update without waiting for the service trigger to settle.
/usr/libexec/cache22/refresh-pending-motd || true

# Desktop notification is now also handled by refresh-pending-motd
# (above), which only fires it on actual none → staged transitions and
# does so for both cache22-update and bare `bootc upgrade` paths.

if (( APPS )); then
    echo "==> flatpak update"
    sudo -u "$(logname 2>/dev/null || echo "$SUDO_USER")" flatpak update -y || \
        echo "WARN: flatpak update reported errors (continuing)"
    if command -v distrobox >/dev/null 2>&1; then
        echo "==> distrobox upgrade --all"
        distrobox upgrade --all || \
            echo "WARN: distrobox upgrade reported errors (continuing)"
    fi
fi

if (( REBOOT )); then
    echo "==> Rebooting via cache22-reboot (auto-picks soft when same-kernel)"
    exec cache22-reboot
fi
