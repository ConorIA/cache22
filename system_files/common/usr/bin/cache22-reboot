#!/usr/bin/env bash
# cache22-reboot — apply a staged update with the optimal reboot
# strategy.
#
# Auto-picks based on what bootc says is possible:
#
#   soft-reboot   bootc reports staged.softRebootCapable=true.
#                 Same kernel keeps running; only userspace pivots
#                 into the staged deploy. ~5 sec, network connections
#                 survive. Default when applicable.
#
#   hard reboot   Kernel changed (soft-reboot not capable). Full system
#                 restart through firmware POST + bootloader. Default
#                 when soft-reboot isn't possible.
#
#   kexec         Kernel changed AND user opted into kexec (via config
#                 or --kexec). Faster than full reboot when hardware
#                 supports it; some hardware doesn't kexec cleanly.
#
# Flags:
#   --soft          Force soft-reboot (fail if not capable, unless
#                   --no-fallback omitted).
#   --kexec         Prefer kexec when the kernel changed.
#   --hard          Force full reboot regardless.
#   --check         Print the strategy that would run; do not execute.
#   --no-fallback   On strategy failure, abort instead of falling back
#                   to a full reboot.
#   --help
#
# Persistent preference: /etc/cache22/reboot.conf
#   KERNEL_CHANGE_STRATEGY=hard|kexec    (default: hard)
#   SOFT_REBOOT=auto|never               (default: auto)
# CLI flags override the config for that invocation.

set -euo pipefail

CONFIG=/etc/cache22/reboot.conf
KERNEL_CHANGE_STRATEGY=hard
SOFT_REBOOT=auto
[[ -f $CONFIG ]] && . "$CONFIG"

FORCE_SOFT=0
FORCE_KEXEC=0
FORCE_HARD=0
CHECK=0
FALLBACK=1

for arg in "$@"; do
    case "$arg" in
        --soft)         FORCE_SOFT=1 ;;
        --kexec)        FORCE_KEXEC=1 ;;
        --hard)         FORCE_HARD=1 ;;
        --check)        CHECK=1 ;;
        --no-fallback)  FALLBACK=0 ;;
        -h|--help)      sed -n '2,33p' "$0" | sed 's/^# \?//'; exit 0 ;;
        *)              echo "Unknown arg: $arg" >&2; exit 1 ;;
    esac
done

die() { echo "Error: $*" >&2; exit 1; }

# ─── State discovery ─────────────────────────────────────────────
status=$(bootc status --json 2>/dev/null || echo '{}')
has_staged=no
soft_capable=false
staged_digest=""

if echo "$status" | jq -e '.status.staged != null' >/dev/null 2>&1; then
    has_staged=yes
    soft_capable=$(echo "$status" | jq -r '.status.staged.softRebootCapable // false')
    staged_digest=$(echo "$status" | jq -r '.status.staged.image.imageDigest // ""')
fi

# ─── Strategy decision ──────────────────────────────────────────
decide() {
    if (( FORCE_HARD ));  then echo hard;  return; fi
    if (( FORCE_KEXEC )); then echo kexec; return; fi
    if (( FORCE_SOFT )); then
        # Honor the user's explicit ask; the executor will fail-fast
        # if soft isn't actually capable.
        echo soft; return
    fi
    if [[ "$has_staged" != "yes" ]]; then
        echo hard; return
    fi
    if [[ "$soft_capable" == "true" && "$SOFT_REBOOT" != "never" ]]; then
        echo soft; return
    fi
    case "$KERNEL_CHANGE_STRATEGY" in
        kexec) echo kexec ;;
        *)     echo hard ;;
    esac
}

strategy=$(decide)

explain() {
    case "$strategy" in
        soft)  echo "soft-reboot (kernel unchanged, fastest)" ;;
        kexec) echo "kexec (kernel changed; --kexec or KERNEL_CHANGE_STRATEGY=kexec)" ;;
        hard)
            if [[ "$has_staged" != "yes" ]]; then
                echo "hard reboot (nothing staged; rebooting current)"
            elif (( FORCE_HARD )); then
                echo "hard reboot (--hard forced)"
            elif [[ "$soft_capable" == "true" && "$SOFT_REBOOT" == "never" ]]; then
                echo "hard reboot (SOFT_REBOOT=never in $CONFIG)"
            else
                echo "hard reboot (kernel changed; set KERNEL_CHANGE_STRATEGY=kexec or pass --kexec for kexec)"
            fi
            ;;
    esac
}

if (( CHECK )); then
    echo "strategy: $strategy — $(explain)"
    if [[ "$has_staged" == "yes" ]]; then
        echo "  staged digest:        ${staged_digest:0:23}…"
        echo "  softRebootCapable:    $soft_capable"
    else
        echo "  staged:               (none)"
    fi
    echo "  KERNEL_CHANGE_STRATEGY: $KERNEL_CHANGE_STRATEGY"
    echo "  SOFT_REBOOT:            $SOFT_REBOOT"
    exit 0
fi

[[ ${EUID} -eq 0 ]] || die "must run as root (try: sudo cache22-reboot)"

fallback() {
    if (( FALLBACK )); then
        echo "==> falling back to hard reboot"
        exec systemctl reboot
    else
        die "$1 failed and --no-fallback set; system unchanged"
    fi
}

# ─── Hard reboot ────────────────────────────────────────────────
# Standard bootc/ostree path: shutdown sequence runs
# ostree-finalize-staged.service ExecStop (which finalizes the staged
# deploy and, via our drop-in, builds the UKI) before the actual
# reboot. No manual orchestration needed here.
do_hard_reboot() {
    echo "==> hard reboot ($(explain))"
    exec systemctl reboot
}

# ─── Soft-reboot ────────────────────────────────────────────────
# Manual orchestration because:
#   1. Soft-reboot doesn't go through the normal shutdown's
#      finalize-staged path the same way (we want to be sure finalize
#      runs BEFORE we try to mount the deploy at /run/nextroot).
#   2. ostree's `ostree admin prepare-soft-reboot` refuses to run on
#      the legacy backend; we replicate the prep ourselves via
#      /usr/libexec/cache22/prepare-soft-reboot.
do_soft_reboot() {
    if [[ "$has_staged" != "yes" ]]; then
        die "no staged deploy — soft-reboot is only meaningful when applying an update"
    fi
    if [[ "$soft_capable" != "true" ]]; then
        if (( FALLBACK )); then
            echo "==> soft-reboot not capable (kernel changed); falling back"
            strategy=$(case "$KERNEL_CHANGE_STRATEGY" in kexec) echo kexec ;; *) echo hard ;; esac)
            case "$strategy" in
                kexec) do_kexec; return ;;
                hard)  do_hard_reboot; return ;;
            esac
        else
            die "staged deploy is not soft-reboot capable (kernel changed)"
        fi
    fi

    echo "==> soft-reboot ($(explain))"

    echo "    finalizing staged deploy"
    ostree admin finalize-staged \
        || { echo "    finalize-staged failed" >&2; fallback "soft-reboot"; return; }

    echo "    building + signing UKI for the new deploy"
    /usr/libexec/cache22/resign-uki \
        || { echo "    resign-uki failed" >&2; fallback "soft-reboot"; return; }

    echo "    populating /run/nextroot"
    /usr/libexec/cache22/prepare-soft-reboot \
        || { echo "    prepare-soft-reboot failed" >&2; fallback "soft-reboot"; return; }

    echo "==> systemctl soft-reboot"
    exec systemctl soft-reboot
}

# ─── kexec ──────────────────────────────────────────────────────
# Picks the UKI sd-boot would auto-default to (highest .osrel
# VERSION_ID across cache22-*.efi). For a staged-but-not-finalized
# deploy, the UKI doesn't exist yet — finalize + build first.
#
# kexec + LUKS+TPM caveat: kexec bypasses sd-stub, so PCR 11 is never
# measured for the new UKI and any keyslot bound to the signed PCR 11
# policy cannot unseal. do_kexec refuses to kexec when the boot LUKS has
# no PCR 7 (signed-policy-free) keyslot, since the resulting passphrase
# prompt is easy to miss after GPU re-init. See `cache22-encryption
# --help` for enrolling the PCR 7 fallback.
do_kexec() {
    echo "==> kexec ($(explain))"

    # Refuse the kexec if the encrypted root could not auto-unlock afterwards.
    # A keyslot is kexec-safe only when it binds plain PCRs (the PCR 7 fallback)
    # with no signed PCR 11 policy: the signed policy needs sd-stub, which kexec
    # skips, so a PCR 11 only or a combined PCR 7 + signed PCR 11 slot fails and
    # the kexec'd kernel lands at a passphrase prompt that is easy to miss after
    # GPU re-init. The token JSON is authoritative; the luksDump tpm2-hash-pcrs
    # summary cannot tell a clean PCR 7 slot from a combined one.
    if command -v cryptsetup >/dev/null 2>&1; then
        local spec realdev tok t luks_seen=0 all_safe=1 dev_safe
        while read -r spec; do
            [[ -n "$spec" ]] || continue
            if [[ "$spec" == /dev/* ]]; then realdev="$spec"; else realdev=$(findfs "$spec" 2>/dev/null); fi
            [[ -b "$realdev" ]] || continue
            cryptsetup isLuks "$realdev" 2>/dev/null || continue
            luks_seen=1
            dev_safe=0
            for t in $(seq 0 31); do
                tok=$(cryptsetup token export --token-id "$t" "$realdev" 2>/dev/null) || continue
                [[ "$tok" == *'"systemd-tpm2"'* ]] || continue
                if [[ "$tok" =~ \"tpm2-pcrs\":\[[0-9] ]] && ! [[ "$tok" =~ \"tpm2_pubkey_pcrs\":\[[0-9] ]]; then
                    dev_safe=1
                fi
            done
            (( dev_safe )) || all_safe=0
        done < <(awk '$1 !~ /^#/ && NF >= 2 {print $2}' /etc/crypttab 2>/dev/null)
        if (( luks_seen && ! all_safe )); then
            cat >&2 <<'EOF'
    kexec aborted: the encrypted root has no kexec-unlockable TPM2 keyslot,
    so the kexec'd kernel would stop at the LUKS passphrase prompt (often
    invisible after GPU re-init). Enroll a PCR 7 kexec fallback first:
        sudo cache22-encryption remove <device>
        sudo cache22-encryption enroll <device>   # answer "y" to the PCR 7 prompt
EOF
            fallback "kexec (LUKS would require a passphrase)"
            return
        fi
    fi

    if [[ "$has_staged" == "yes" ]]; then
        echo "    finalizing staged deploy"
        ostree admin finalize-staged \
            || { echo "    finalize-staged failed" >&2; fallback "kexec"; return; }
        echo "    building + signing UKI for the new deploy"
        /usr/libexec/cache22/resign-uki \
            || { echo "    resign-uki failed" >&2; fallback "kexec"; return; }
    fi

    local ESP=/efi
    [[ -d "$ESP" ]] || ESP=/boot/efi
    local UKI_DIR="$ESP/EFI/Linux"
    [[ -d "$UKI_DIR" ]] || { echo "ESP UKI directory not found at $UKI_DIR" >&2; fallback "kexec"; return; }

    local KEYDIR=/var/lib/cache22/sbkey
    local SBKEY="$KEYDIR/keys/db/db.key"
    local SBCRT="$KEYDIR/keys/db/db.pem"

    local best="" best_ver=-1 uki ver osrel
    shopt -s nullglob
    for uki in "$UKI_DIR"/cache22-*.efi; do
        osrel=$(objcopy -O binary --only-section=.osrel "$uki" /dev/stdout 2>/dev/null | tr -d '\0' || true)
        ver=$(echo "$osrel" | sed -n 's/^VERSION_ID=//p' | head -1)
        [[ -z "$ver" ]] && continue
        if (( ver > best_ver )); then
            best_ver=$ver
            best="$uki"
        fi
    done
    shopt -u nullglob
    [[ -n "$best" ]] || { echo "No cache22 UKI found in $UKI_DIR" >&2; fallback "kexec"; return; }
    echo "    target UKI: $(basename "$best")"

    local TMP
    TMP=$(mktemp -d)
    trap "rm -rf $TMP" EXIT

    objcopy -O binary --only-section=.linux   "$best" "$TMP/vmlinuz" 2>/dev/null \
        || { echo "Could not extract .linux section" >&2; fallback "kexec"; return; }
    objcopy -O binary --only-section=.initrd  "$best" "$TMP/initrd"  2>/dev/null \
        || { echo "Could not extract .initrd section" >&2; fallback "kexec"; return; }
    objcopy -O binary --only-section=.cmdline "$best" "$TMP/cmdline" 2>/dev/null \
        || { echo "Could not extract .cmdline section" >&2; fallback "kexec"; return; }

    local CMDLINE
    CMDLINE=$(tr -d '\0' < "$TMP/cmdline")
    [[ -n "$CMDLINE" ]] || { echo "Extracted cmdline is empty" >&2; fallback "kexec"; return; }

    # Sign kernel with per-machine SB key so kexec works under kernel
    # lockdown (Fedora-style). Harmless if lockdown is off (Arch default).
    if [[ -f "$SBKEY" && -f "$SBCRT" ]]; then
        if sbsign --key "$SBKEY" --cert "$SBCRT" --output "$TMP/vmlinuz.signed" "$TMP/vmlinuz" >/dev/null 2>&1; then
            mv "$TMP/vmlinuz.signed" "$TMP/vmlinuz"
        fi
    fi

    if ! kexec --load --kexec-syscall-auto \
            "$TMP/vmlinuz" \
            --initrd="$TMP/initrd" \
            --command-line="$CMDLINE"; then
        echo "    kexec --load failed" >&2
        fallback "kexec"
        return
    fi
    echo "==> systemctl kexec"
    exec systemctl kexec
}

case "$strategy" in
    soft)  do_soft_reboot ;;
    kexec) do_kexec ;;
    hard)  do_hard_reboot ;;
esac
