[Unit]
Description=cache22 unattended OS update timer
ConditionPathExists=/etc/cache22/autoupdate.conf

[Timer]
# Baseline: default-desktop profile (Silverblue-style). cache22-autoupdate
# enable writes a drop-in that selects the actual profile or a custom
# OnCalendar. Persistent=true is kept across all profiles — it's what
# catches missed firings when a laptop wakes from suspend.
OnBootSec=1h
OnUnitInactiveSec=1d
RandomizedDelaySec=30min
Persistent=true

[Install]
WantedBy=timers.target
