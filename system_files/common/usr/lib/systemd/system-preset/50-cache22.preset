# cache22 default service enablement.
# Applied at image-build time via `systemctl preset-all --preset-mode=full`
# in finalize-image.sh — both `enable` and `disable` rules take effect.

enable NetworkManager.service
enable systemd-resolved.service
enable systemd-timesyncd.service

# We use NetworkManager exclusively for system networking. systemd-networkd
# ships enabled by upstream presets in some package sets, but it doesn't
# know about NM-managed interfaces — its wait-online unit then sits at
# `activating` for the full 2-minute default timeout on every boot,
# stalling network-online.target and anything that orders After=
# network-online (incus, libvirtd, etc.) for that long. Disable both.
disable systemd-networkd.service
disable systemd-networkd.socket
disable systemd-networkd-wait-online.service
# sshd on by default for both variants — servers need it to log in,
# and most KDE-variant users want it for remote access too. Bind it
# to a less-public port + key-only auth in /etc/ssh/sshd_config if
# you don't want password auth on a public network.
enable sshd.service

# Display manager (only useful in the kde variant; for server, the
# plasmalogin unit is absent and the preset rule silently no-ops).
enable plasmalogin.service

# System services
enable bluetooth.service
enable cups.service
enable cups.socket
enable avahi-daemon.service
enable fwupd.service
enable power-profiles-daemon.service
enable switcheroo-control.service
enable fstrim.timer

# Container infra
enable podman.socket

# cache22-resign-uki: rebuild + sign + place the per-deploy UKI on the
# ESP whenever bootc state changes (upgrade, switch, rollback, edit).
# Path watchers fire on /ostree/bootc mtime (bootc bumps it on every
# state-changing op via bootc-status-updated.path) and on
# /etc/cache22/extra-cmdline edits (so cache22-karg changes trigger a
# rebuild even without a bootc upgrade).
enable cache22-resign-uki.path

# Mask systemd-boot-update.service: it would copy the unsigned sd-boot
# binary from /usr/lib/systemd/boot/efi/ over our locally-signed copy
# on the ESP. cache22-resign-uki re-signs sd-boot itself when the in-
# image version is newer than the ESP version.
disable systemd-boot-update.service

# NOTE: /etc-writability post-soft-reboot is handled by a drop-in on
# ostree-remount.service (50-cache22-etc-rw.conf) — no separate unit
# to enable here.

# Pending-reboot MOTD marker — refreshed on every boot (hard or soft) and
# on bootc state changes. Replaces the previous inline write in
# cache22-update, which left a stale marker after soft-reboot because
# /run survives the userspace pivot.
enable cache22-pending-motd.service

# Post-boot health checks; auto-rollback after 3 consecutive failed boots.
# Triggered by a 2-min OnBootSec timer (NOT WantedBy=multi-user.target —
# that creates a deadlock since the check would wait for itself to finish).
enable cache22-healthcheck.timer

# One-shot Switch-to-Desktop helper: re-applies gamescope autologin at
# next boot. No-op when /var/lib/cache22/gamescope-restore-on-next-boot
# isn't present (per-unit ConditionPathExists).
enable cache22-gamescope-restore.service
