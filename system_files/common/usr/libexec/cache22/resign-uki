#!/usr/bin/env bash
# Build + sign + place a UKI on the ESP for every live bootc deploy.
# Triggered by cache22-resign-uki.{path,service} after bootc state
# changes. Always-signs; if the per-machine SB key is missing, calls
# sb-key-init to generate one first.
#
# Inputs (read):
#   bootc status --json              — list of deploys, ordering
#   /sysroot/ostree/deploy/<state>/deploy/<csum>/usr/lib/modules/<kver>/{vmlinuz,initramfs.img}
#   /etc/cache22/extra-cmdline       — user kargs (newline-separated)
#   /usr/lib/bootc/kargs.d/*.toml    — image-default kargs
#   /var/lib/cache22/sbkey/          — per-machine SB + TPM keys
#
# Outputs (write):
#   /efi/EFI/Linux/cache22-<csum>.efi   — one signed UKI per deploy
#   /efi/EFI/systemd/systemd-bootx64.efi — re-signed sd-boot if newer
#
# Atomicity: every ESP write is to <name>.tmp + fsync + rename. GC
# of stale UKIs runs only after all desired UKIs are confirmed present.

set -euo pipefail

KEYDIR=/var/lib/cache22/sbkey
SBKEY="$KEYDIR/keys/db/db.key"
SBCRT="$KEYDIR/keys/db/db.pem"
TPM_KEY="$KEYDIR/tpm-pcr11.key"
TPM_PUB="$KEYDIR/tpm-pcr11.pub"
EXTRA_CMDLINE=/etc/cache22/extra-cmdline
ESP=/efi
[[ -d "$ESP" ]] || ESP=/boot/efi
UKI_DIR="$ESP/EFI/Linux"
SDBOOT_DIR="$ESP/EFI/systemd"
SDBOOT_SRC=/usr/lib/systemd/boot/efi/systemd-bootx64.efi

require_root() {
    [[ ${EUID} -eq 0 ]] || { echo "resign-uki: must run as root" >&2; exit 1; }
}
die() { echo "resign-uki: $*" >&2; exit 1; }

require_root

[[ -d "$ESP" ]] || die "ESP not mounted (looked at /efi and /boot/efi)"

# Ensure SB + TPM keys exist. Always-signs invariant.
if [[ ! -f "$SBKEY" || ! -f "$TPM_KEY" ]]; then
    /usr/libexec/cache22/sb-key-init
fi
[[ -f "$SBKEY" && -f "$SBCRT" ]] || die "SB key missing after sb-key-init"
[[ -f "$TPM_KEY" && -f "$TPM_PUB" ]] || die "TPM key missing after sb-key-init"

install -d -m 0755 "$UKI_DIR" "$SDBOOT_DIR"

# Read user-managed kargs. Newline-separated; '#' comments + blanks ignored.
read_user_kargs() {
    [[ -f "$EXTRA_CMDLINE" ]] || return 0
    sed -e 's/[[:space:]]*#.*$//' -e '/^[[:space:]]*$/d' "$EXTRA_CMDLINE"
}

# Locate /boot. At runtime it lives at /boot. At install time the
# chroot's /boot is empty (deploy ships an empty /boot) so we look at
# /sysroot/boot — install_sb_and_uki bind-mounts the partition root to
# /sysroot inside the chroot.
boot_dir() {
    if [[ -d /boot/ostree ]]; then
        echo /boot
    elif [[ -d /sysroot/boot/ostree ]]; then
        echo /sysroot/boot
    else
        die "Could not locate ostree's /boot (checked /boot and /sysroot/boot)"
    fi
}

# Enumerate BLS entries ostree wrote per deploy. The active boot version
# (boot.0 or boot.1) flips on each deploy; ostree maintains the
# /boot/loader symlink to the active loader.X dir. As a fallback (eg at
# install time before finalize wires the symlink) we walk both
# loader.0 and loader.1 explicitly.
list_bls_entries() {
    local boot
    boot=$(boot_dir)
    if [[ -L "$boot/loader" ]] && [[ -d "$boot/loader/entries" ]]; then
        find "$boot/loader/entries" -name 'ostree-*.conf' 2>/dev/null
    else
        find "$boot/loader.0/entries" "$boot/loader.1/entries" \
             -name 'ostree-*.conf' 2>/dev/null
    fi
}

# Read a single BLS entry into globals: BLS_LINUX, BLS_INITRD,
# BLS_OPTIONS, BLS_VERSION. linux=/initrd= are partition-relative (start
# with /boot/...); we leave them as-is and prepend $boot/.. at use time.
parse_bls() {
    local entry="$1"
    BLS_LINUX="" BLS_INITRD="" BLS_OPTIONS="" BLS_VERSION=""
    while IFS= read -r line; do
        case "$line" in
            linux\ *)   BLS_LINUX="${line#linux }" ;;
            initrd\ *)  BLS_INITRD="${line#initrd }" ;;
            options\ *) BLS_OPTIONS="${line#options }" ;;
            version\ *) BLS_VERSION="${line#version }" ;;
        esac
    done < "$entry"
}

# Atomic copy: write to .tmp, fsync, rename. ESP is FAT32, no journal,
# so partial writes are the failure mode to defend against.
atomic_install() {
    local src="$1" dst="$2" tmp
    tmp="${dst}.tmp.$$"
    cp "$src" "$tmp"
    sync -f "$tmp" 2>/dev/null || sync
    mv -f "$tmp" "$dst"
}

# Build one UKI from one BLS entry. Echoes the expected ESP filename.
# The BLS entry's options= line is the source of truth for the cmdline
# (it contains the correct ostree=/ostree/boot.X/<state>/<bootcsum>/0
# path, root=, image-default kargs from /usr/lib/bootc/kargs.d/, etc.).
# Append user kargs from /etc/cache22/extra-cmdline.
build_uki_from_bls() {
    local entry="$1" version_priority="$2"
    parse_bls "$entry"
    [[ -n "$BLS_LINUX"  ]] || { echo "    SKIP: no linux= in $entry" >&2; return 1; }
    [[ -n "$BLS_INITRD" ]] || { echo "    SKIP: no initrd= in $entry" >&2; return 1; }
    [[ -n "$BLS_OPTIONS" ]] || { echo "    SKIP: no options= in $entry" >&2; return 1; }

    # BLS linux=/initrd= paths are partition-relative (/boot/ostree/...).
    # Prefix with /sysroot if our boot lives there.
    local boot prefix
    boot=$(boot_dir)
    case "$boot" in
        /boot)         prefix="" ;;
        /sysroot/boot) prefix="/sysroot" ;;
        *)             prefix="$(dirname "$boot")" ;;
    esac
    local vmlinuz="${prefix}${BLS_LINUX}"
    local initramfs="${prefix}${BLS_INITRD}"
    [[ -f "$vmlinuz"   ]] || die "vmlinuz not found at $vmlinuz (BLS linux=$BLS_LINUX)"
    [[ -f "$initramfs" ]] || die "initramfs not found at $initramfs (BLS initrd=$BLS_INITRD)"

    # bootcsum = the sha256 in the linux= path:
    # /boot/ostree/<stateroot>-<bootcsum>/vmlinuz-<kver>
    local bootcsum
    bootcsum=$(echo "$BLS_LINUX" | sed -n 's|.*/ostree/[^/]*-\([0-9a-f]\{64\}\)/.*|\1|p')
    [[ -n "$bootcsum" ]] || die "Could not parse bootcsum from $BLS_LINUX"

    # kver from the vmlinuz filename suffix.
    local kver
    kver=$(basename "$BLS_LINUX" | sed -n 's|^vmlinuz-||p')
    [[ -n "$kver" ]] || die "Could not parse kver from $BLS_LINUX"

    # Cmdline = BLS options= + user extras.
    local user_extra
    user_extra=$(read_user_kargs | tr '\n' ' ')
    local cmdline="$BLS_OPTIONS"
    [[ -n "$user_extra" ]] && cmdline="$cmdline $user_extra"
    cmdline=$(echo "$cmdline" | sed 's/  */ /g; s/^ //; s/ $//')

    local out_name="cache22-${bootcsum:0:16}.efi"
    local out_path="$UKI_DIR/$out_name"
    local tmp_uki
    tmp_uki=$(mktemp --suffix=.efi)

    # version_priority → .osrel VERSION_ID. sd-boot sorts by it
    # descending and picks the highest as default.
    local osrel
    osrel=$(mktemp)
    cat > "$osrel" <<EOF
NAME="cache22"
ID=cache22
PRETTY_NAME="cache22 deploy ${bootcsum:0:8}"
VERSION_ID=${version_priority}
VERSION="${version_priority}"
EOF

    echo "==> Building UKI for ${bootcsum:0:16} (kver=$kver, prio=$version_priority)"
    ukify build \
        --linux="$vmlinuz" \
        --initrd="$initramfs" \
        --cmdline="$cmdline" \
        --uname="$kver" \
        --os-release="@$osrel" \
        --secureboot-private-key="$SBKEY" \
        --secureboot-certificate="$SBCRT" \
        --pcr-private-key="$TPM_KEY" \
        --pcr-public-key="$TPM_PUB" \
        --pcr-banks=sha256 \
        --output="$tmp_uki"
    rm -f "$osrel"

    atomic_install "$tmp_uki" "$out_path"
    rm -f "$tmp_uki"
    echo "    wrote $out_path"
    printf '%s\n' "$out_name"
}

# Sign + install sd-boot if the on-ESP copy is missing, unsigned, or
# older than the in-image binary. bootctl install copies an UNSIGNED
# sd-boot to the ESP — so on every install we MUST re-sign once. mtime
# alone isn't enough; check signature presence too.
sync_sd_boot() {
    [[ -f "$SDBOOT_SRC" ]] || die "sd-boot source $SDBOOT_SRC missing (systemd package broken?)"
    local dst="$SDBOOT_DIR/systemd-bootx64.efi"
    local fallback="$ESP/EFI/BOOT/BOOTX64.EFI"

    local need_install=0
    if [[ ! -f "$dst" ]]; then
        need_install=1
    elif ! sbverify --list "$dst" 2>/dev/null | grep -q 'image signature issuers'; then
        # On-ESP sd-boot has no signature (typical post bootctl-install
        # state). Without re-signing, firmware refuses to load it under
        # SB enforcement.
        need_install=1
    elif [[ "$SDBOOT_SRC" -nt "$dst" ]]; then
        need_install=1
    fi

    if (( need_install )); then
        echo "==> Signing + installing sd-boot to $dst"
        local tmp
        tmp=$(mktemp --suffix=.efi)
        sbsign --key "$SBKEY" --cert "$SBCRT" --output "$tmp" "$SDBOOT_SRC"
        install -d -m 0755 "$SDBOOT_DIR" "$ESP/EFI/BOOT"
        atomic_install "$tmp" "$dst"
        atomic_install "$tmp" "$fallback"
        rm -f "$tmp"
    fi
}

# Garbage-collect UKIs not in the keep set. Run only after all builds
# succeed so a partial run never deletes a working UKI.
gc_ukis() {
    local keep_set="$1"
    local f basename
    shopt -s nullglob
    for f in "$UKI_DIR"/cache22-*.efi; do
        basename=$(basename "$f")
        if ! grep -qxF "$basename" <<<"$keep_set"; then
            echo "==> GC: removing stale $basename"
            rm -f "$f"
        fi
    done
    shopt -u nullglob
}

# Main: walk BLS entries, build UKI for each, sync sd-boot, GC.
# We use BLS entries instead of walking the deploy tree because
# (a) ostree picks the boot.X version dynamically and the BLS entry
# already encodes the right ostree= path, (b) the BLS entry's options=
# already includes image kargs + root= written by bootc/ostree at
# install/deploy time, and (c) one BLS entry exists per live deploy.
main() {
    local entries
    entries=$(list_bls_entries | sort)
    [[ -n "$entries" ]] || die "no ostree-*.conf BLS entries found in $(boot_dir)"

    # version_priority: BLS entries are named ostree-N.conf where N is a
    # monotonic counter ostree increments per deploy (newer = higher N,
    # newer = more recent = should boot first). Use N as the priority
    # directly; sd-boot picks highest. Add 1000 so the namespace is
    # well-separated from any fallback UKI someone manually drops in.
    local keep_set=""
    local entry n prio uki_name
    while IFS= read -r entry; do
        [[ -z "$entry" ]] && continue
        n=$(basename "$entry" .conf | sed -n 's|^ostree-\([0-9]*\)|\1|p')
        [[ -z "$n" ]] && n=1
        prio=$(( 1000 + n ))
        uki_name=$(build_uki_from_bls "$entry" "$prio") || continue
        keep_set+="${uki_name}"$'\n'
    done <<<"$entries"

    [[ -n "$keep_set" ]] || die "no UKIs were built — refusing to GC"

    sync_sd_boot
    gc_ukis "$keep_set"

    sync -f "$ESP" 2>/dev/null || sync
    echo "==> resign-uki done"
}

main "$@"
